# ============================================================
# TruckMap — Variables d'environnement pour production Docker
# ============================================================
# Copier ce fichier en .env, remplir toutes les valeurs,
# puis configurer dans Dokploy (Settings > Environment).
# NE JAMAIS commiter le fichier .env avec des vraies valeurs.

APP_NAME=TruckMap
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://votre-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=14

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Base de données ─────────────────────────────────────────
# DB_HOST doit correspondre au nom du service dans docker-compose.yml
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=truckmap
DB_USERNAME=root
DB_PASSWORD=                      # Mot de passe fort requis

# ── Session ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.votre-domaine.com

# ── Queue & Cache ────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Email Gmail SMTP ─────────────────────────────────────────
# Créer un App Password sur : myaccount.google.com/apppasswords
# (nécessite 2FA activé sur le compte Google)
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre.adresse@gmail.com
MAIL_PASSWORD=                    # App Password Google (16 caractères sans espaces)
MAIL_FROM_ADDRESS=votre.adresse@gmail.com
MAIL_FROM_NAME=TruckMap

# ── Vite ─────────────────────────────────────────────────────
VITE_APP_NAME=TruckMap
